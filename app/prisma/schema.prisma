// Novum Scheduler — Prisma schema (initial cut, Sprint 0)
//
// Conventions:
//   - All IDs are cuid()
//   - createdAt / updatedAt on every mutable entity
//   - Project + Task carry externalId/externalSource for future Asana import
//   - Notes are append-only (no updatedAt — edits would happen via a soft-delete + replace later if ever needed)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  scheduler
  installer
}

enum TaskStatus {
  pending
  in_progress
  done
  blocked
}

enum DeficiencySeverity {
  cosmetic
  functional
  safety
}

enum DeficiencyStatus {
  open
  scheduled
  fixed
  waived
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  name         String
  passwordHash String
  role         Role     @default(installer)
  color        String?  // hex; used as the installer's column accent on the board
  active       Boolean  @default(true)
  icsToken     String?  @unique // per-user public token for ICS calendar feed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks     Task[]             @relation("AssignedInstaller")
  notes             Note[]
  auditLogs         AuditLog[]
  pushSubscriptions PushSubscription[]
  timeEntries       TimeEntry[]
  deficienciesRaised   Deficiency[] @relation("DeficiencyRaised")
  deficienciesResolved Deficiency[] @relation("DeficiencyResolved")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. 'task.create', 'task.move', 'task.status'
  entityType String   // 'task' | 'project' | 'user' | 'note'
  entityId   String
  metadata   Json?    // action-specific payload (before/after, etc.)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  clientName     String?
  color          String?
  status         String   @default("active")
  externalId     String?  // for Asana / future imports
  externalSource String?
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks Task[]

  @@index([externalSource, externalId])
}

model Task {
  id                   String     @id @default(cuid())
  projectId            String
  title                String
  description          String?
  scheduledDate        DateTime?  // null while in the project pool
  scheduledOrder       Int?       // ordering within an installer's column for that date (legacy; less meaningful with time slots)
  scheduledStartMinute Int?       // minutes from local midnight (480 = 8am, 540 = 9am, …). null = on-day but not pinned to a time.
  estimatedMinutes     Int?       // duration estimate. null = unspecified; UI defaults to 60min when rendering.
  assignedInstallerId  String?
  status               TaskStatus @default(pending)
  externalId           String?
  externalSource       String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  installer        User?   @relation("AssignedInstaller", fields: [assignedInstallerId], references: [id], onDelete: SetNull)
  notes            Note[]
  timeEntries      TimeEntry[]
  deficiencies     Deficiency[]  @relation("DeficiencySource")
  fixesDeficiency  Deficiency?   @relation("DeficiencyFix")
  checklist        TaskChecklist?

  @@index([assignedInstallerId, scheduledDate])
  @@index([projectId])
  @@index([externalSource, externalId])
}

model Note {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  body      String
  createdAt DateTime @default(now())

  task   Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  photos NotePhoto[]

  @@index([taskId, createdAt])
}

/// Per-task time-tracking entry. Single-active model: a user has at most
/// one entry with `stoppedAt = null` at a time. Starting a new timer
/// auto-stops any prior running entry. Stop is terminal — to add more
/// time on the same task, start a new entry. The Task.actualMinutes
/// rollup (sum of all stopped entries) lives in app code, not the DB.
///
/// `source` traces who/what created the entry: 'manual' for the field
/// tech tapping Start, 'admin_edit' for an admin backfilling on the
/// time-entries page (a forgot-to-start fix). Audit log carries the
/// before/after for admin edits.
model TimeEntry {
  id        String    @id @default(cuid())
  taskId    String
  userId    String
  startedAt DateTime  @default(now())
  stoppedAt DateTime?
  source    String    @default("manual")
  note      String?
  createdAt DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Hot path: "is this user currently running a timer?" → look up
  // (userId, stoppedAt=null). Index covers it.
  @@index([userId, stoppedAt])
  @@index([taskId, startedAt])
}

/// Reusable checklist template. `items` is a JSON array of
/// `{ id, label, required }` rows; the per-task instance copies this
/// array at apply-time so future template edits don't retroactively
/// invalidate finished work. Sprint 5 cut: all items implicitly
/// required + free-form text only. Photo-required + signature kinds
/// land in P1 once the client portal exists.
model ChecklistTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  items       Json     // [{ id, label, required }, ...]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskChecklists TaskChecklist[]
}

/// Per-task instance of a checklist. `items` is a snapshot of the
/// template's items at apply-time, decorated with per-row state:
/// `{ id, label, required, checkedAt?, checkedById? }`. The
/// setTaskStatus close-out gate refuses `done` while any item with
/// `required = true` is missing `checkedAt`.
model TaskChecklist {
  id         String   @id @default(cuid())
  taskId     String   @unique
  templateId String
  items      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  task     Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  template ChecklistTemplate @relation(fields: [templateId], references: [id])
}

/// Punch-list item raised against a task that survives task closure.
/// Lifted from InspectHub's deficiency model. Severity drives the
/// fix-window (safety = 24h, functional = 14d, cosmetic = 30d) and the
/// task close-out gate refuses `done` while open functional/safety
/// items remain. `fixTaskId` optionally points at the follow-up Task
/// the scheduler spawned to resolve it.
model Deficiency {
  id           String              @id @default(cuid())
  taskId       String              // task that surfaced it
  raisedById   String              // user who raised it
  description  String
  severity     DeficiencySeverity  @default(functional)
  status       DeficiencyStatus    @default(open)
  dueBy        DateTime?           // computed from severity at create time
  fixTaskId    String?  @unique    // optional follow-up Task; spawn-on-schedule
  resolvedAt   DateTime?
  resolvedById String?
  resolvedNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task       Task @relation("DeficiencySource", fields: [taskId], references: [id], onDelete: Cascade)
  fixTask    Task? @relation("DeficiencyFix", fields: [fixTaskId], references: [id], onDelete: SetNull)
  raisedBy   User @relation("DeficiencyRaised", fields: [raisedById], references: [id], onDelete: Restrict)
  resolvedBy User? @relation("DeficiencyResolved", fields: [resolvedById], references: [id], onDelete: SetNull)
  photos     DeficiencyPhoto[]

  @@index([status, dueBy])
  @@index([taskId])
}

/// Mirror of NotePhoto — same on-disk processing pipeline (sharp JPEG)
/// and same `/api/photos/[id]` serving route reused. `kind` = 'before'
/// captured at deficiency raise; 'after' captured at resolution.
model DeficiencyPhoto {
  id           String     @id @default(cuid())
  deficiencyId String
  kind         String     // 'before' | 'after'
  path         String
  width        Int
  height       Int
  sizeBytes    Int
  createdAt    DateTime   @default(now())

  deficiency Deficiency @relation(fields: [deficiencyId], references: [id], onDelete: Cascade)

  @@index([deficiencyId])
}

model NotePhoto {
  id        String   @id @default(cuid())
  noteId    String
  path      String   // path under the /uploads volume
  width     Int
  height    Int
  sizeBytes Int
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}
