// Novum Scheduler — Prisma schema (initial cut, Sprint 0)
//
// Conventions:
//   - All IDs are cuid()
//   - createdAt / updatedAt on every mutable entity
//   - Project + Task carry externalId/externalSource for future Asana import
//   - Notes are append-only (no updatedAt — edits would happen via a soft-delete + replace later if ever needed)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  scheduler
  installer
}

enum TaskStatus {
  pending
  in_progress
  done
  blocked
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  name         String
  passwordHash String
  role         Role     @default(installer)
  color        String?  // hex; used as the installer's column accent on the board
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks Task[]     @relation("AssignedInstaller")
  notes         Note[]
  auditLogs     AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. 'task.create', 'task.move', 'task.status'
  entityType String   // 'task' | 'project' | 'user' | 'note'
  entityId   String
  metadata   Json?    // action-specific payload (before/after, etc.)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  clientName     String?
  color          String?
  status         String   @default("active")
  externalId     String?  // for Asana / future imports
  externalSource String?
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks Task[]

  @@index([externalSource, externalId])
}

model Task {
  id                  String     @id @default(cuid())
  projectId           String
  title               String
  description         String?
  scheduledDate       DateTime?  // null while in the project pool
  scheduledOrder      Int?       // ordering within an installer's column for that date
  assignedInstallerId String?
  status              TaskStatus @default(pending)
  externalId          String?
  externalSource      String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  installer User?   @relation("AssignedInstaller", fields: [assignedInstallerId], references: [id], onDelete: SetNull)
  notes     Note[]

  @@index([assignedInstallerId, scheduledDate])
  @@index([projectId])
  @@index([externalSource, externalId])
}

model Note {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  body      String
  createdAt DateTime @default(now())

  task   Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  photos NotePhoto[]

  @@index([taskId, createdAt])
}

model NotePhoto {
  id        String   @id @default(cuid())
  noteId    String
  path      String   // path under the /uploads volume
  width     Int
  height    Int
  sizeBytes Int
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}
