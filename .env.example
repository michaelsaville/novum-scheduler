# Copy to .env and fill in real values. .env is gitignored.

# Postgres
POSTGRES_PASSWORD=change-me

# Prisma
DATABASE_URL=postgresql://novum:change-me@db:5432/novum?schema=public

# Next.js / Auth.js (Sprint 1)
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=https://novum.pcc2k.com

# Web push (generate via: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Same value as VAPID_PUBLIC_KEY but with NEXT_PUBLIC_ prefix so the
# browser can read it during the subscribe flow.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
